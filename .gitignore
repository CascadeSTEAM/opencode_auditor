# Sensitive system-specific data (stored locally only - visible in Obsidian)
private/

# Generated metrics (not useful for others - sanitized version kept)
metrics/*.json
!metrics/README.md

# Obsidian config (personal — root only, setup/ref templates are tracked)
.obsidian/
!setup/.obsidian/

# OpenCode local config (personal model settings — file is tracked)
.opencode/node_modules/
.opencode/package.json
.opencode/package-lock.json

# Temp and backup files
*.bak
*~
*.tmp
setup/INSTALL.md.bak*
setup/install.sh.bak*

# Build artifacts
node_modules/
