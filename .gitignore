# Generated metrics (not useful for others - sanitized version kept)
metrics/*.json
!metrics/README.md

# Obsidian config (personal — root only, setup/ref templates are tracked)
.obsidian/
!setup/.obsidian/

# OpenCode local dev artifacts (if they appear)
.opencode/node_modules/
.opencode/package.json
.opencode/package-lock.json

# Temp and backup files
*.bak
*~
*.tmp
setup/INSTALL.md.bak*
setup/install.sh.bak*

# Vault version marker (legacy — replaced by mitigations/ existence check)
.vault-version

# Plan files (active audit output — local only, not tracked)
audits/

# Mitigation files (scan remediation output — local only; keep dir placeholder)
mitigations/*
!mitigations/.gitkeep

# Startup marker (regenerated by install.sh)
.startup-required

# Build artifacts
node_modules/
